# Database Configuration
MONGO_URI=mongodb://localhost:27017/cognizenx
# MONGO_URL is an alternative name for MONGO_URI (both work)

# Server Configuration
PORT=6000
NODE_ENV=development

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Semantic dedup for generated questions (same category + subDomain)
SEMANTIC_SIMILARITY_THRESHOLD=0.85
EMBEDDING_MODEL=text-embedding-3-small

# Email Configuration (for password reset)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Reset Password URL (optional, defaults to current host)
RESET_URL=http://localhost:6000/reset-password

# Rate limiting (per 15 minutes)
# Auth routes (/api/auth/*) are always limited per IP.
# Logged-in API calls are limited per account (Bearer token); anonymous calls per IP.
AUTH_RATE_LIMIT_MAX=15
GLOBAL_RATE_LIMIT_MAX_ANON=80
GLOBAL_RATE_LIMIT_MAX_USER=400

# Generate a secure random token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-secure-random-token-here

# Personalized quiz + demand-aware cron
FRESH_SLOTS_RATIO=0.7
FRESH_SLOTS_PER_QUIZ=7
USER_EXHAUSTION_RATIO=0.9
MAX_WEEKLY_PER_SUBDOMAIN=50
MAX_WEEKLY_TOTAL_QUESTIONS=500
CRON_CRITICAL_BATCH=40
CRON_HOT_BATCH=20
CRON_WARM_BATCH=10
CRON_EMPTY_BATCH=50

{
    "version": 2,
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api",
        "dest": "index.js"
        },
        {
        "src": "/api/(.*)",
        "dest": "index.js"
      }
    ],
    "crons": [
      {
        "path": "/api/internal/generate-weekly-questions",
        "schedule": "0 2 * * 0"
      }
    ]
  }
  
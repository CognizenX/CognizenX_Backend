# Database Configuration
MONGO_URI=mongodb://localhost:27017/cognizenx
# MONGO_URL is an alternative name for MONGO_URI (both work)

# Server Configuration
PORT=6000
NODE_ENV=development

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Configuration (for password reset)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Reset Password URL (optional, defaults to current host)
RESET_URL=http://localhost:6000/reset-password

# Cron Job Authentication (for weekly question generation)
# Generate a secure random token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-secure-random-token-here
